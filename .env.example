# ============================================================
# .env — Environment Variables ERP Cuci Sepatu
# JANGAN commit file ini ke Git! Tambahkan ke .gitignore
# ============================================================

# ── SUPABASE ──────────────────────────────────────────────
# Dapatkan dari: https://supabase.com/dashboard/project/[project]/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── TELEGRAM ──────────────────────────────────────────────
# Token dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLL...

# Chat ID tujuan notifikasi (grup atau personal)
# Cara dapat: buka https://api.telegram.org/bot[TOKEN]/getUpdates
# lalu cari "chat":{"id": ANGKA_INI}
TELEGRAM_CHAT_ID=987654321
